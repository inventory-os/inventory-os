# Database backend: sqlite3 (default) or pg
DB_CLIENT=sqlite3

# SQLite file path (used when DB_CLIENT=sqlite3)
SQLITE_FILENAME=./inventory-os.sqlite

# Postgres connection string (used when DB_CLIENT=pg)
DATABASE_URL=postgresql://user:password@localhost:5432/inventory_os

# Public domain/base URL used for QR payload links
# Examples: https://assets.your-company.com or app.your-company.com
APP_DOMAIN=http://localhost:3000

# Path template used to build the QR destination URL.
# Use {id} where the asset id should be inserted.
APP_QR_PATH_TEMPLATE=/assets/{id}

# Local filesystem directory where uploaded asset images/documents are stored.
# Can be absolute path, or relative to project root.
ASSET_STORAGE_DIR=./storage/assets

AUTH_SESSION_SECRET=replace-with-a-long-random-secret

# OIDC login configuration
OIDC_ISSUER_URL=https://auth.example.com/application/o/inventory-os
OIDC_CLIENT_ID=replace-with-client-id
OIDC_CLIENT_SECRET=replace-with-client-secret
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback
OIDC_SCOPE=openid profile email

# OIDC claim-based role mapping (admin/member only)
OIDC_ROLE_CLAIM=roles
OIDC_ADMIN_ROLE_VALUE=admin
OIDC_MEMBER_ROLE_VALUE=member

# If true, first login can auto-create local users (source=jit).
OIDC_JIT_CREATE=false

# On first run, the app opens /welcome where admin user, language,
# and first base location are created.
